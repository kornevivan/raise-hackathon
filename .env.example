# Copy to .env and fill in after verifying your Vultr account email and creating a
# Serverless Inference subscription (Portal → Serverless Inference → Add).
# The app runs fully in deterministic offline mode until VULTR_INFERENCE_API_KEY is set.

# Inference subscription key (NOT the account API key). Enables live Vultr mode.
VULTR_INFERENCE_API_KEY=

# Reasoning model ids — lock these from `python backend/probe_vultr.py`.
VULTR_MODEL_PRIME=qwen2.5-72b-instruct
VULTR_MODEL_CORE=qwen2.5-32b-instruct
VULTR_MODEL_FLASH=qwen2.5-7b-instruct

# VultronRetriever flavors (document retrieval, escalated by difficulty).
VULTR_RETRIEVER_PRIME=VultronRetrieverPrime-Qwen3.5-8B
VULTR_RETRIEVER_CORE=VultronRetrieverCore-Qwen3.5-4.5B
VULTR_RETRIEVER_FLASH=VultronRetrieverFlash-Qwen3.5-0.8B

# UI trace pacing in ms (raise for a calmer demo, 0 for instant).
DEMO_PACE_MS=420

# Optional: your domain for automatic HTTPS via Caddy.
SITE_ADDRESS=
